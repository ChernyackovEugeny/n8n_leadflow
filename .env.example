# Copy this file to .env before running Docker Compose.
# Do not commit real secrets.

# PostgreSQL
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=leadflow
POSTGRES_PORT=5432

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Moscow
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string

# Future LLM provider settings
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=change_me
LLM_MODEL=gpt-4.1-mini

# Future Telegram integration
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_MANAGER_CHAT_ID=change_me

# Future Google Sheets integration
GOOGLE_SHEETS_SPREADSHEET_ID=change_me

# Future IMAP integration
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=sales@example.com
IMAP_PASSWORD=change_me
